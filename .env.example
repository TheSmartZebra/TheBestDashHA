# Home Assistant connection (required)
# Base URL of your Home Assistant instance, reachable from wherever this
# server process runs (e.g. http://homeassistant.local:8123 on your LAN,
# or a Nabu Casa / reverse-proxy URL if this app runs off-network).
HA_URL=http://homeassistant.local:8123

# Long-lived access token: HA Profile -> Security -> Long-Lived Access Tokens.
# Never committed, never sent to the browser -- read only by server.ts / server/*.
HA_TOKEN=

# Session secret for this app's own login (iron-session). Generate with:
#   openssl rand -base64 32
APP_SESSION_SECRET=

# Password gating access to this app (single-household use).
APP_PASSWORD=

# Port the Next.js + WS relay server listens on.
PORT=3000
